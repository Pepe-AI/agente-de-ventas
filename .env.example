# Twilio credentials (Console > Account Info). Never commit the real .env.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# WhatsApp sender. For the sandbox this is Twilio's shared number.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Redis connection. On Render use the internal Redis URL (set in the dashboard).
REDIS_URL=redis://localhost:6379/0

# LLM (Gemini).
GEMINI_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-3.5-flash

# Trip schema a new conversation starts on: cruise | europe | asia.
TRIP_TYPE=cruise

# Concurrency tunables (optional; sensible defaults shown).
DEBOUNCE_WINDOW_S=3
DEDUP_TTL_S=3600
LOCK_TTL_S=30
RATE_WINDOW_S=10
RATE_THRESHOLD=15
BLOCK_COOLDOWN_S=600
BUFFER_MAX=10
