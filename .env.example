# Twilio credentials (Console > Account Info). Never commit the real .env.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# WhatsApp sender. For the sandbox this is Twilio's shared number.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Redis connection. On Render use the internal Redis URL (set in the dashboard).
REDIS_URL=redis://localhost:6379/0

# Postgres connection (durable conversation state). Render provides DATABASE_URL;
# respect its SSL parameters. Run migrations once: python -m app.storage.migrate
DATABASE_URL=postgresql://user:pass@localhost:5432/topviajes

# LLM (Gemini).
GEMINI_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-3.5-flash

# Campaign pre-fill phrases for trip-type routing (placeholders until G1).
# When a phrase appears in the first message, it routes to that trip type.
# PREFILL_CRUCERO=
# PREFILL_EUROPA=
# PREFILL_ASIA=

# Concurrency tunables (optional; sensible defaults shown).
DEBOUNCE_WINDOW_S=3
DEDUP_TTL_S=3600
LOCK_TTL_S=30
RATE_WINDOW_S=10
RATE_THRESHOLD=15
BLOCK_COOLDOWN_S=600
BUFFER_MAX=10
